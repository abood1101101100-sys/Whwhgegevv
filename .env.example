# انسخ هذا الملف إلى ".env" واملأ القيم الحقيقية. لا ترفع ".env" نفسه لأي
# مستودع Git (تأكد أنه مُدرج في .gitignore).

# --- Telegram Bot (من BotFather) ---
BOT_TOKEN=
SUDO_ID=
BOT_USERNAME=

# --- Pyrogram / Telegram API (من my.telegram.org) ---
API_ID=
API_HASH=

# --- Userbot session (اختياري) ---
USERBOT_SESSION_STRING=

# --- ARQ API (اختياري) ---
ARQ_API_KEY=
ARQ_API_URL=https://arq.hamker.dev

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- kvsqlite (اتركها افتراضية إلا لو لك سبب لتغييرها) ---
YTDB_PATH=ytdb.sqlite
SOUNDDB_PATH=sounddb.sqlite
WSDB_PATH=wsdb.sqlite
